# Ignore build artifacts and cache
/target/

# Ignore IDE files (.git is kept so build.rs / vergen-gitcl can read commit info)
.gitignore
*.swp
*.swo
*~
.vscode/
.idea/

# Ignore documentation and non-essential files
README.md
LICENSE
assets/

# Ignore test files (they're copied separately if needed)
/tests/

# Docker files themselves
Dockerfile
.dockerignore